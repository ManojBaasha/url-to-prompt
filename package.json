{
  "name": "url-to-prompt",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "verify:screenshot": "tsx --env-file=.env.local scripts/verify-screenshot.ts",
    "verify:vision": "tsx --env-file=.env.local scripts/verify-vision.ts",
    "verify:db": "tsx --env-file=.env.local scripts/verify-db.ts",
    "docs:export": "tsx scripts/export-openapi.ts",
    "docs:lint": "redocly lint api/openapi-snapshot.yaml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@hono/zod-openapi": "^1.3.0",
    "@sparticuz/chromium": "^147.0.1",
    "@vercel/postgres": "^0.10.0",
    "hono": "^4.12.14",
    "puppeteer-core": "^24.41.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@redocly/cli": "^2.28.1",
    "@types/node": "^25.6.0",
    "puppeteer": "^24.41.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vercel": "^51.7.0",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
